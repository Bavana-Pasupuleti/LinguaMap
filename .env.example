# Reddit (no API key needed — uses public JSON endpoints)
REDDIT_USER_AGENT=LinguaMap/1.0 (Anthropological Language Tracker)

# Mastodon (get from your instance Settings > Development > New Application)
# Only needs 'read' scope (read:statuses + read:search)
MASTODON_ACCESS_TOKEN=your_access_token
MASTODON_INSTANCE_URL=https://mastodon.social

# NewsAPI (get from https://newsapi.org/register)
NEWSAPI_KEY=your_newsapi_key

# Database (leave empty for SQLite local dev, or set for PostgreSQL)
# DATABASE_URL=postgresql://linguamap:linguamap@localhost:5432/linguamap

# Redis (leave empty for in-memory cache)
# REDIS_URL=redis://localhost:6379/0

# Pipeline schedule (cron format — default 3am UTC daily)
CRON_SCHEDULE=0 3 * * *

# Airflow
AIRFLOW_UID=50000
